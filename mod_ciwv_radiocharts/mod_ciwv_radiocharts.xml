<?xml version="1.0" encoding="utf-8"?>
<extension type="module" version="4.0" client="site" method="upgrade">
    <name>mod_ciwv_radiocharts</name>
    <author>Gonzo Radio / Durham Radio Inc.</author>
    <version>3.0.0</version>
    <description>Interactive radio-chart dashboard for CIWV. Merges Station Playlist, National Chart, Luminate streaming data, Music Master and Billboard into a sortable, week-tracked dashboard with DB-backed state.</description>
    <files>
        <filename module="mod_ciwv_radiocharts">mod_ciwv_radiocharts.php</filename>
        <filename>helper.php</filename>
        <filename>index.html</filename>
        <folder>tmpl</folder>
        <folder>ajax</folder>
        <folder>media</folder>
        <folder>data-examples</folder>
        <folder>sql</folder>
        <folder>language</folder>
    </files>
    <languages>
        <language tag="en-GB">language/en-GB/mod_ciwv_radiocharts.ini</language>
        <language tag="en-GB">language/en-GB/mod_ciwv_radiocharts.sys.ini</language>
    </languages>
    <install>
        <sql>
            <file driver="mysql" charset="utf8">sql/install.mysql.utf8.sql</file>
        </sql>
    </install>
    <config>
        <fields name="params">
            <fieldset name="basic" label="Basic Settings">
                <field
                    name="station"
                    type="text"
                    label="Station Callsign"
                    description="Station identifier, e.g. CIWV."
                    default="CIWV"
                />
                <field
                    name="data_path"
                    type="text"
                    label="Data Directory (optional)"
                    description="Leave blank to use the default folder (modules/mod_ciwv_radiocharts/data). If set, provide a path relative to the Joomla root."
                    default=""
                />
                <field
                    name="allowed_csv_types"
                    type="checkboxes"
                    label="Enable Upload Types"
                    description="Select which CSV upload types to accept."
                    multiple="true"
                >
                    <option value="national">National Playlist</option>
                    <option value="station">Station Playlist</option>
                    <option value="streaming_station">Streaming Data (Station / National)</option>
                    <option value="streaming_market">Streaming Data (Market)</option>
                    <option value="musicmaster">Music Master CSV</option>
                    <option value="billboard">Billboard Chart</option>
                </field>
                <field
                    name="example_notice"
                    type="spacer"
                    label="CSV Template Location"
                    description="Sample CSV files for each source type are in /modules/mod_ciwv_radiocharts/data-examples/."
                />
            </fieldset>
        </fields>
    </config>
</extension>