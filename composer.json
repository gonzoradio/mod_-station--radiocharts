{
    "name": "gonzoradio/mod_ciwv_radiocharts",
    "description": "Joomla 4/5 module and task plugins for CIWV radio charts data",
    "type": "joomla-module",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Gonzo Radio",
            "email": "dev@gonzoradio.com"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5.22"
    },
    "autoload": {
        "psr-4": {
            "Gonzoradio\\Module\\CiwvRadiocharts\\Site\\": "mod_ciwv_radiocharts/src/",
            "Gonzoradio\\Plugin\\Task\\CiwvRadiochartsMediabaseNational\\": "plugins/task/ciwv_radiocharts_mediabase_national/src/",
            "Gonzoradio\\Plugin\\Task\\CiwvRadiochartsMediabaseLocal\\": "plugins/task/ciwv_radiocharts_mediabase_local/src/",
            "Gonzoradio\\Plugin\\Task\\CiwvRadiochartsLuminate\\": "plugins/task/ciwv_radiocharts_luminate/src/",
            "Gonzoradio\\Plugin\\Task\\CiwvRadiochartsMusicmaster\\": "plugins/task/ciwv_radiocharts_musicmaster/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gonzoradio\\Tests\\": "tests/"
        }
    }
}
